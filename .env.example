# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Google Sheet ID (from the sheet URL)
SHEET_ID=

# WhatsApp numbers in international format (e.g. +1...)
OUTREACH_NUMBER=
HR_NUMBER=

# Path to your Chrome profile used for WhatsApp Web
CHROME_PROFILE_DIR=

# xAI Grok API key — get one at https://console.x.ai/
# Leave blank to use keyword-based classification instead
GROK_API_KEY=

# Gmail sender address and App Password (NOT your login password)
# How to get an App Password: Google Account → Security → 2-Step Verification → App passwords
GMAIL_SENDER=
GMAIL_APP_PASSWORD=

# Comma-separated list of email addresses to receive the daily report
REPORT_RECIPIENTS=

# Telegram bot token — get from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram chat IDs allowed to control the bot
# Get your chat ID: message the bot, then open https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_ALLOWED_IDS=

# Comma-separated Telegram chat IDs that receive HR reply notifications
HR_TELEGRAM_IDS=
